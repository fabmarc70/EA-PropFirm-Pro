rules_version = '2';

// ══════════════════════════════════════════════════════════════════
// RÈGLES DE SÉCURITÉ FIRESTORE — EA PropFirm Pro
// Séparation stricte des comptes (RLS) : chaque utilisateur ne peut
// lire/écrire QUE son propre document users/{uid}.
// ══════════════════════════════════════════════════════════════════
service cloud.firestore {
  match /databases/{database}/documents {

    // Profil utilisateur : users/{uid}
    match /users/{uid} {
      // Lecture/écriture autorisées uniquement si l'utilisateur est
      // authentifié ET que l'uid du document correspond à son propre uid.
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Sous-collections futures (journal, configs, simulations) :
    // même règle d'isolation par uid.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Tout le reste est refusé par défaut.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
